<Window x:Class="Anis.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Anis.App"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="Anis Settings" Height="450" Width="600"
        Closing="Window_Closing">

    <Grid>
        <!-- This is the System Tray Icon definition -->
        <tb:TaskbarIcon
            x:Name="MyNotifyIcon"
            IconSource="/Assets/icon.ico"
            ToolTipText="Anis - شغال في الخلفية"
            TrayMouseDoubleClick="MyNotifyIcon_TrayMouseDoubleClick">

            <!-- This is the context menu (right-click menu) -->
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="الإعدادات" Click="Settings_Click" />
                    <MenuItem Header="إيقاف مؤقت" IsCheckable="True" />
                    <Separator />
                    <MenuItem Header="الخروج" Click="Exit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>

        </tb:TaskbarIcon>

        <TextBlock Text="هنا ستكون صفحة الإعدادات" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" />
    </Grid>
</Window>